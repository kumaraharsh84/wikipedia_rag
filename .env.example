# Copy this file to .env for local development or add these keys in Vercel.

JWT_SECRET=change-me-in-production-use-a-long-random-string
API_KEY=

# LLM provider
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Vector store
VECTOR_STORE=faiss
PINECONE_API_KEY=
PINECONE_INDEX=wiki-qa

# Feature flags
ENABLE_RERANKER=true
ENABLE_GENERATOR=true

# Optional Docker/Grafana settings
DOCKER_IMAGE=yourdockerh/wiki-qa:latest
GRAFANA_PASSWORD=admin
