{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend_react/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{tests/**,eval/**,grafana/**,scripts/**,frontend_react/**,data/**,.git/**,.github/**,Dockerfile,docker-compose.yml,prometheus.yml,SCALING.md,README.md}"
    }
  }
}
